{
  "name": "web-animation",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:api": "tsx watch server/dev.ts",
    "build": "tsc -b && vite build",
    "build:vercel": "vite build",
    "typecheck:server": "tsc -p tsconfig.server.json --noEmit",
    "lint": "eslint .",
    "preview": "vite preview",
    "knip": "knip",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:relocate-demo-animation-css": "tsx server/scripts/relocate-demo-animation-css.ts",
    "db:fix-broken-css-react-demos": "tsx server/scripts/fix-broken-css-react-demos.ts",
    "db:remove-tailwind-css-files": "tsx server/scripts/remove-tailwind-css-files.ts",
    "env:check": "tsx server/scripts/check-env.ts",
    "admin:seed": "BETTER_AUTH_ALLOW_SIGNUP=true tsx server/scripts/ensure-admin.ts"
  },
  "dependencies": {
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-html": "^6.4.11",
    "@hono/node-server": "^1.19.9",
    "@neondatabase/serverless": "^1.0.2",
    "@uiw/codemirror-theme-github": "^4.25.4",
    "@uiw/react-codemirror": "^4.25.4",
    "better-auth": "^1.4.18",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.12.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.13.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@react-dev-inspector/babel-plugin": "^2.0.1",
    "@react-dev-inspector/vite-plugin": "^2.0.1",
    "@tailwindcss/vite": "^4.1.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "dotenv": "^17.3.1",
    "drizzle-kit": "^0.31.9",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^28.1.0",
    "knip": "^5.84.1",
    "prettier": "^3.5.0",
    "prettier-plugin-tailwindcss": "^0.6.0",
    "react-dev-inspector": "^2.0.1",
    "tailwindcss": "^4.1.0",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  },
  "knip": {
    "ignore": [
      "api/admin/[...route].ts",
      "src/tailwind-demo-safelist.ts"
    ],
    "ignoreDependencies": [
      "@react-dev-inspector/babel-plugin"
    ]
  }
}

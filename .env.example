REACT_EDITOR=cursor

# Neon connection string (pooled URL recommended for production)
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/dbname?sslmode=require

# Better Auth
BETTER_AUTH_SECRET=replace-with-a-long-random-secret
BETTER_AUTH_URL=http://localhost:5173
BETTER_AUTH_TRUSTED_ORIGINS=http://localhost:5173,http://localhost:8787
BETTER_AUTH_ALLOW_SIGNUP=false

# Single admin account
ADMIN_EMAIL=ben@modernthings.net
ADMIN_NAME=ben
ADMIN_PASSWORD=change-me-before-seeding

# Local API runtime
API_PORT=8787
VITE_API_ORIGIN=http://localhost:8787
